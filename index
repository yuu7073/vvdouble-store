<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VV DOUBLE 店長中心</title>

<!-- Firebase compat 版（依 skill 規範，禁用 modular） -->
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>

<style>
/* ============================================
   主題系統 - CSS 變數
   ============================================ */
:root {
  /* Theme A: 陽光黃（預設） */
  --primary: #FFD93D;
  --primary-dark: #1A1A1A;
  --primary-light: #FFF8E0;
  --primary-bg: #FFF8E7;
  --primary-text-on-primary: #1A1A1A;
  --primary-text-on-dark: #FFD93D;
  --accent-orange: #FF6B35;
  --accent-blue: #2D5BFF;
  --accent-pink: #FFB5D1;

  /* 通用色 */
  --text-primary: #1A1A1A;
  --text-secondary: #555555;
  --text-tertiary: #888888;
  --text-light: #BBBBBB;
  --bg-white: #FFFFFF;
  --bg-gray-50: #FAFAFA;
  --bg-gray-100: #F5F5F5;
  --border-light: #F0F0F0;
  --border-medium: #E0E0E0;
  --border-dark: #C0C0C0;

  /* 狀態色 */
  --success: #4CD964;
  --success-bg: #EAF3DE;
  --success-text: #1B5E20;
  --warning: #FFB800;
  --warning-bg: #FFFBEC;
  --warning-text: #5C4A1A;
  --danger: #FF6B35;
  --danger-bg: #FFF5F2;
  --danger-text: #7A2D1A;

  /* 其他 */
  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 14px;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
  --shadow-lg: 0 10px 40px rgba(0,0,0,0.15);
  --transition: 0.2s ease;
}

/* Theme B: 薄荷藍 */
[data-theme="mint"] {
  --primary: #4ECDC4;
  --primary-dark: #1A3A52;
  --primary-light: #E8F8F6;
  --primary-bg: #F0F9F8;
  --primary-text-on-primary: #FFFFFF;
  --primary-text-on-dark: #4ECDC4;
  --accent-orange: #FF6B6B;
  --accent-blue: #2D5BFF;
  --accent-pink: #FFE66D;
}

/* Theme C: 糖果拼色 */
[data-theme="candy"] {
  --primary: #FFB5D1;
  --primary-dark: #1A1A1A;
  --primary-light: #FFE5F0;
  --primary-bg: #FFFFFF;
  --primary-text-on-primary: #1A1A1A;
  --primary-text-on-dark: #FFB5D1;
  --accent-orange: #FF6B35;
  --accent-blue: #2D5BFF;
  --accent-pink: #FFE5A0;
}

/* ============================================
   全局樣式
   ============================================ */
* { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  font-family: 'Microsoft JhengHei', 'PingFang TC', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 14px;
  color: var(--text-primary);
  background: var(--primary-bg);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

button { font-family: inherit; cursor: pointer; }
input, textarea, select { font-family: inherit; }

/* ============================================
   登入畫面
   ============================================ */
#loginScreen {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  background: var(--primary-bg);
}

.login-card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 32px 28px;
  width: 100%;
  max-width: 400px;
  box-shadow: var(--shadow-md);
  border: 1px solid var(--primary-light);
}

.login-logo {
  width: 56px;
  height: 56px;
  background: var(--primary-dark);
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary-text-on-dark);
  font-size: 18px;
  font-weight: 800;
  margin: 0 auto 16px;
}

.login-title {
  font-size: 20px;
  font-weight: 800;
  text-align: center;
  margin-bottom: 4px;
}

.login-subtitle {
  font-size: 12px;
  color: var(--text-tertiary);
  text-align: center;
  margin-bottom: 24px;
}

.login-step {
  margin-bottom: 16px;
}

.login-label {
  font-size: 12px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6px;
  display: block;
}

.login-input {
  width: 100%;
  padding: 11px 14px;
  border: 1.5px solid var(--border-medium);
  border-radius: var(--radius-md);
  font-size: 14px;
  background: var(--bg-white);
  transition: border-color var(--transition);
}

.login-input:focus {
  outline: none;
  border-color: var(--primary);
}

.login-button {
  width: 100%;
  padding: 12px;
  background: var(--primary-dark);
  color: var(--primary-text-on-dark);
  border: none;
  border-radius: var(--radius-md);
  font-size: 14px;
  font-weight: 700;
  margin-top: 8px;
  transition: opacity var(--transition);
}

.login-button:hover:not(:disabled) { opacity: 0.85; }
.login-button:disabled { opacity: 0.4; cursor: not-allowed; }

.login-button.secondary {
  background: var(--bg-white);
  color: var(--text-secondary);
  border: 1px solid var(--border-medium);
}

.login-error {
  font-size: 12px;
  color: var(--danger);
  margin-top: 8px;
  padding: 8px 12px;
  background: var(--danger-bg);
  border-radius: var(--radius-sm);
  display: none;
}

.login-error.show { display: block; }

.staff-list {
  max-height: 280px;
  overflow-y: auto;
  border: 1px solid var(--border-medium);
  border-radius: var(--radius-md);
  background: var(--bg-white);
}

.staff-option {
  padding: 12px 14px;
  border-bottom: 1px solid var(--border-light);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: background var(--transition);
}

.staff-option:last-child { border-bottom: none; }
.staff-option:hover { background: var(--primary-light); }

.staff-option.selected {
  background: var(--primary-light);
  border-left: 3px solid var(--primary);
}

.staff-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--primary);
  color: var(--primary-text-on-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  flex-shrink: 0;
}

.staff-info { flex: 1; }
.staff-name { font-size: 13px; font-weight: 600; }
.staff-role { font-size: 11px; color: var(--text-tertiary); margin-top: 2px; }

.staff-empty {
  padding: 20px;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 13px;
}

.staff-add-trigger {
  padding: 10px 14px;
  text-align: center;
  font-size: 12px;
  color: var(--primary-text-on-primary);
  background: var(--primary-light);
  border-top: 1px solid var(--border-light);
  cursor: pointer;
  font-weight: 600;
}

.staff-add-trigger:hover { background: var(--primary); }

/* ============================================
   主應用框架
   ============================================ */
#mainApp {
  display: none;
  min-height: 100vh;
  background: var(--primary-bg);
}

.app-header {
  background: var(--primary);
  padding: 12px 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: var(--shadow-sm);
}

.app-header-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.app-logo {
  width: 32px;
  height: 32px;
  background: var(--primary-dark);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary-text-on-dark);
  font-size: 12px;
  font-weight: 800;
}

.app-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--primary-text-on-primary);
}

.app-subtitle {
  font-size: 11px;
  color: var(--primary-text-on-primary);
  opacity: 0.75;
  font-weight: 500;
}

.app-header-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.header-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(0,0,0,0.08);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background var(--transition);
  position: relative;
}

.header-btn:hover { background: rgba(0,0,0,0.15); }
.header-btn svg { width: 16px; height: 16px; stroke: var(--primary-text-on-primary); stroke-width: 2; fill: none; }

.app-content {
  padding: 16px;
  max-width: 1200px;
  margin: 0 auto;
}

/* ============================================
   主題切換器
   ============================================ */
.theme-popup {
  position: absolute;
  top: 50px;
  right: 16px;
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 14px;
  width: 240px;
  box-shadow: var(--shadow-lg);
  border: 1px solid var(--border-light);
  display: none;
  z-index: 200;
}

.theme-popup.show { display: block; }

.theme-popup-title {
  font-size: 11px;
  color: var(--text-tertiary);
  font-weight: 700;
  margin-bottom: 10px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.theme-option {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px;
  border: 2px solid var(--border-light);
  border-radius: var(--radius-md);
  cursor: pointer;
  margin-bottom: 6px;
  background: var(--bg-white);
  transition: all var(--transition);
}

.theme-option:last-child { margin-bottom: 0; }
.theme-option:hover { border-color: var(--primary); }

.theme-option.active {
  background: var(--primary-light);
  border-color: var(--primary);
}

.theme-swatches {
  display: flex;
  gap: 3px;
  flex-shrink: 0;
}

.theme-swatch {
  width: 14px;
  height: 14px;
  border-radius: 4px;
}

.theme-info { flex: 1; }
.theme-name { font-size: 12px; font-weight: 700; color: var(--text-primary); }
.theme-desc { font-size: 10px; color: var(--text-tertiary); margin-top: 1px; }
.theme-check svg { width: 14px; height: 14px; stroke: var(--text-primary); stroke-width: 2.5; fill: none; }
.theme-check { display: none; }
.theme-option.active .theme-check { display: block; }

.theme-popup-footer {
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid var(--border-light);
  font-size: 10px;
  color: var(--text-tertiary);
  text-align: center;
}

/* ============================================
   首頁（暫存佔位，後續模組會填充）
   ============================================ */
.welcome-card {
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 100%);
  border-radius: var(--radius-lg);
  padding: 18px;
  margin-bottom: 16px;
}

.welcome-text {
  font-size: 14px;
  color: var(--primary-text-on-primary);
  line-height: 1.6;
  font-weight: 500;
}

.welcome-text strong { font-weight: 800; }

.placeholder-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 16px;
}

.placeholder-card {
  background: var(--bg-white);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-md);
  padding: 16px;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 12px;
}

.placeholder-card strong {
  display: block;
  color: var(--text-primary);
  font-size: 13px;
  margin-bottom: 4px;
}

/* ============================================
   員工管理畫面
   ============================================ */
.staff-mgmt-screen {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 18px;
  border: 1px solid var(--border-light);
}

.staff-mgmt-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.staff-mgmt-title { font-size: 14px; font-weight: 800; }

.btn-primary {
  padding: 8px 14px;
  background: var(--primary-dark);
  color: var(--primary-text-on-dark);
  border: none;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  transition: opacity var(--transition);
}

.btn-primary:hover { opacity: 0.85; }
.btn-primary svg { width: 12px; height: 12px; stroke: currentColor; stroke-width: 3; fill: none; }

.btn-ghost {
  padding: 6px 12px;
  background: var(--bg-white);
  color: var(--text-secondary);
  border: 1px solid var(--border-medium);
  border-radius: var(--radius-sm);
  font-size: 11px;
  font-weight: 600;
  transition: background var(--transition);
}

.btn-ghost:hover { background: var(--bg-gray-50); }

.btn-danger {
  padding: 6px 12px;
  background: var(--bg-white);
  color: var(--danger);
  border: 1px solid var(--danger);
  border-radius: var(--radius-sm);
  font-size: 11px;
  font-weight: 600;
}

.btn-danger:hover { background: var(--danger-bg); }

.staff-mgmt-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.staff-mgmt-item {
  background: var(--bg-gray-50);
  border-radius: var(--radius-md);
  padding: 10px 14px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.staff-mgmt-item.inactive { opacity: 0.5; }

.staff-mgmt-info { flex: 1; }
.staff-mgmt-name { font-size: 13px; font-weight: 700; }
.staff-mgmt-meta { font-size: 11px; color: var(--text-tertiary); margin-top: 2px; }

/* ============================================
   彈窗（CSS checkbox hack 為主，這裡用 JS 切換 class）
   ============================================ */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 20px;
}

.modal-overlay.show { display: flex; }

.modal-box {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  width: 100%;
  max-width: 420px;
  max-height: 90vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-lg);
}

.modal-header {
  background: var(--primary);
  padding: 14px 18px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-title { font-size: 14px; font-weight: 800; color: var(--primary-text-on-primary); }

.modal-close {
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close svg { width: 16px; height: 16px; stroke: var(--primary-text-on-primary); stroke-width: 2.5; fill: none; }

.modal-body {
  padding: 18px;
  overflow-y: auto;
  flex: 1;
}

.modal-footer {
  padding: 12px 18px;
  border-top: 1px solid var(--border-light);
  background: var(--bg-gray-50);
  display: flex;
  gap: 8px;
}

.form-group { margin-bottom: 14px; }
.form-label { font-size: 11px; font-weight: 700; margin-bottom: 6px; display: block; }
.form-required { color: var(--danger); }

.form-input, .form-select {
  width: 100%;
  padding: 10px 12px;
  border: 1.5px solid var(--border-medium);
  border-radius: var(--radius-md);
  font-size: 13px;
  background: var(--bg-white);
  transition: border-color var(--transition);
}

.form-input:focus, .form-select:focus {
  outline: none;
  border-color: var(--primary);
}

/* ============================================
   通用元件
   ============================================ */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(255,255,255,0.85);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-overlay.show { display: flex; }

.spinner {
  width: 36px;
  height: 36px;
  border: 3px solid var(--border-medium);
  border-top-color: var(--primary-dark);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.toast {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(100px);
  background: var(--primary-dark);
  color: var(--primary-text-on-dark);
  padding: 12px 20px;
  border-radius: var(--radius-md);
  font-size: 13px;
  font-weight: 600;
  box-shadow: var(--shadow-lg);
  z-index: 10000;
  opacity: 0;
  transition: all 0.3s ease;
}

.toast.show {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
}

.toast.error { background: var(--danger); color: white; }
.toast.success { background: var(--success); color: white; }

/* ============================================
   響應式
   ============================================ */
@media (max-width: 600px) {
  .app-content { padding: 12px; }
  .placeholder-grid { grid-template-columns: 1fr; }
  .modal-box { max-width: 100%; }
}

</style>
</head>

<body>

<!-- ============================================
     登入畫面
     ============================================ -->
<div id="loginScreen">
  <div class="login-card">
    <div class="login-logo">VV</div>
    <div class="login-title">店長中心</div>
    <div class="login-subtitle">VV DOUBLE Store Manager Hub</div>

    <!-- Step 1: 店帳號密碼 -->
    <div id="loginStep1">
      <div class="login-step">
        <label class="login-label">店帳號</label>
        <select class="login-input" id="loginStoreId">
          <option value="">選擇你的店家...</option>
          <option value="zhongxiao">台北忠孝旗艦</option>
          <option value="tongyi">台北統一 3F</option>
          <option value="taoyuan">桃園 ATT</option>
          <option value="yizhong">台中一中旗艦</option>
          <option value="xinyizhong">台中新一中</option>
          <option value="xintiandi">台南新天地 4F</option>
          <option value="xinjuejiang">高雄新堀江</option>
          <option value="V">總部 V</option>
        </select>
      </div>
      <div class="login-step">
        <label class="login-label">密碼</label>
        <input type="password" class="login-input" id="loginPassword" placeholder="請輸入密碼" autocomplete="current-password">
      </div>
      <div class="login-error" id="loginError"></div>
      <button class="login-button" id="loginBtnStep1">下一步</button>
    </div>

    <!-- Step 2: 選值班人員（總部 V 跳過） -->
    <div id="loginStep2" style="display: none;">
      <div class="login-step">
        <label class="login-label">選擇今天值班的我是誰</label>
        <div class="staff-list" id="staffSelectList">
          <!-- 動態載入 -->
        </div>
        <div class="staff-add-trigger" id="addStaffTrigger">+ 新增員工</div>
      </div>
      <button class="login-button" id="loginBtnStep2" disabled>進入店長中心</button>
      <button class="login-button secondary" id="loginBtnBack" style="margin-top: 6px;">返回</button>
    </div>

  </div>
</div>

<!-- ============================================
     主應用
     ============================================ -->
<div id="mainApp">
  <header class="app-header">
    <div class="app-header-left">
      <div class="app-logo">VV</div>
      <div>
        <div class="app-title" id="appTitle">店長中心</div>
        <div class="app-subtitle" id="appSubtitle">值班：—</div>
      </div>
    </div>
    <div class="app-header-right">
      <!-- 員工管理 (只店長/V 顯示) -->
      <button class="header-btn" id="staffMgmtBtn" title="員工管理">
        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      </button>

      <!-- 主題切換 -->
      <div style="position: relative;">
        <button class="header-btn" id="themeToggleBtn" title="切換主題">
          <svg viewBox="0 0 24 24"><circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 011.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
        </button>
      </div>

      <!-- 登出 -->
      <button class="header-btn" id="logoutBtn" title="登出">
        <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
      </button>
    </div>
  </header>

  <!-- 主題切換彈窗 -->
  <div class="theme-popup" id="themePopup">
    <div class="theme-popup-title">選擇主題</div>

    <div class="theme-option" data-theme="sunshine">
