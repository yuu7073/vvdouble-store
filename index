// 員工管理
// ============================================
function setupStaffManagement() {
  document.getElementById('staffMgmtBtn').addEventListener('click', openStaffMgmt);
  document.getElementById('staffMgmtBackBtn').addEventListener('click', closeStaffMgmt);
  document.getElementById('staffMgmtAddBtn').addEventListener('click', () => openAddStaffModal('mgmt'));
  document.getElementById('addStaffTrigger').addEventListener('click', () => openAddStaffModal('login'));
  document.getElementById('addStaffCloseBtn').addEventListener('click', closeAddStaffModal);
  document.getElementById('addStaffCancelBtn').addEventListener('click', closeAddStaffModal);
  document.getElementById('addStaffConfirmBtn').addEventListener('click', confirmAddStaff);
}

function openStaffMgmt() {
  if (state.isHQ) {
    showToast('總部視角的員工管理將在後續版本開放', '');
    return;
  }
  document.getElementById('homeScreen').style.display = 'none';
  document.getElementById('staffMgmtScreen').style.display = 'block';
  document.getElementById('staffMgmtSubtitle').textContent = STORE_NAMES[state.storeId];
  loadStaffMgmtList();
}

function closeStaffMgmt() {
  document.getElementById('staffMgmtScreen').style.display = 'none';
  document.getElementById('homeScreen').style.display = 'block';
}

async function loadStaffMgmtList() {
  if (!db) {
    document.getElementById('staffMgmtList').innerHTML =
      '<div class="staff-empty" style="padding: 30px;">Firebase 尚未設定，無法載入員工列表</div>';
    return;
  }
  try {
    const snapshot = await db.ref(`/stores/${state.storeId}/staff`).once('value');
    const data = snapshot.val() || {};
    const list = Object.entries(data).map(([id, info]) => ({ id, ...info }));
    renderStaffMgmtList(list);
  } catch (err) {
    showToast('載入失敗：' + err.message, 'error');
  }
}

function renderStaffMgmtList(list) {
  const container = document.getElementById('staffMgmtList');
  if (!list || list.length === 0) {
    container.innerHTML = '<div class="staff-empty" style="padding: 30px;">尚未新增員工，點右上角「新增員工」開始</div>';
    return;
  }

  // 排序：在職在前，離職在後
  list.sort((a, b) => {
    const aActive = a.active !== false ? 1 : 0;
    const bActive = b.active !== false ? 1 : 0;
    return bActive - aActive;
  });

  container.innerHTML = list.map(s => {
    const isActive = s.active !== false;
    return `
      <div class="staff-mgmt-item ${isActive ? '' : 'inactive'}">
        <div class="staff-avatar">${escapeHtml(getAvatarText(s.name))}</div>
        <div class="staff-mgmt-info">
          <div class="staff-mgmt-name">${escapeHtml(s.name)} ${isActive ? '' : '<span style="font-size:10px;color:var(--text-tertiary);">(已停用)</span>'}</div>
          <div class="staff-mgmt-meta">${escapeHtml(s.role || '店員')} · 加入於 ${formatDate(s.createdAt)}</div>
        </div>
        ${isActive
          ? `<button class="btn-danger" data-action="deactivate" data-id="${s.id}">停用</button>`
          : `<button class="btn-ghost" data-action="reactivate" data-id="${s.id}">重新啟用</button>`}
      </div>
    `;
  }).join('');

  // 綁定停用/啟用按鈕
  container.querySelectorAll('button[data-action]').forEach(btn => {
    btn.addEventListener('click', () => {
      const action = btn.dataset.action;
      const id = btn.dataset.id;
      if (action === 'deactivate') deactivateStaff(id);
      if (action === 'reactivate') reactivateStaff(id);
    });
  });
}

async function deactivateStaff(staffId) {
  if (!confirm('確定要停用此員工嗎？\n（資料會保留，可隨時重新啟用，不會刪除歷史紀錄）')) return;
  setLoading(true);
  const result = await safeUpdate(`/stores/${state.storeId}/staff/${staffId}`, { active: false });
  setLoading(false);
  if (result.success) {
    showToast('已停用', 'success');
    loadStaffMgmtList();
  }
}

async function reactivateStaff(staffId) {
  setLoading(true);
  const result = await safeUpdate(`/stores/${state.storeId}/staff/${staffId}`, { active: true });
  setLoading(false);
  if (result.success) {
    showToast('已重新啟用', 'success');
    loadStaffMgmtList();
  }
}

// 共用：新增員工彈窗
let addStaffOrigin = 'login'; // 'login' 或 'mgmt'

function openAddStaffModal(origin) {
  addStaffOrigin = origin;
  document.getElementById('newStaffName').value = '';
  document.getElementById('newStaffRole').value = '店員';
  document.getElementById('addStaffModal').classList.add('show');
  setTimeout(() => document.getElementById('newStaffName').focus(), 100);
}

function closeAddStaffModal() {
  document.getElementById('addStaffModal').classList.remove('show');
}

async function confirmAddStaff() {
  const name = document.getElementById('newStaffName').value.trim();
  const role = document.getElementById('newStaffRole').value;

  if (!name) {
    showToast('請輸入姓名', 'error');
    return;
  }
  if (name.length > 20) {
    showToast('姓名過長（最多 20 字）', 'error');
    return;
  }

  // 決定要新增到哪個店（登入流程 = 當前選的店；員工管理 = 當前登入店）
  const targetStoreId = state.storeId;
  if (!targetStoreId) {
    showToast('店家狀態異常', 'error');
    return;
  }

  if (!db) {
    showToast('Firebase 尚未設定，無法新增', 'error');
    return;
  }

  setLoading(true);
  try {
    const newRef = db.ref(`/stores/${targetStoreId}/staff`).push();
    await newRef.set({
      name,
      role,
      active: true,
      createdAt: Date.now(),
      createdBy: state.currentStaff || 'self-register'
    });
    showToast('新增成功', 'success');
    closeAddStaffModal();

    // 依來源刷新列表
    if (addStaffOrigin === 'login') {
      await loadStaffListForLogin();
    } else {
      await loadStaffMgmtList();
    }
  } catch (err) {
    showToast('新增失敗：' + err.message, 'error');
  } finally {
    setLoading(false);
  }
}

// ============================================
// 主題切換器
// ============================================
function setupThemeSwitcher() {
  const btn = document.getElementById('themeToggleBtn');
  const popup = document.getElementById('themePopup');

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    popup.classList.toggle('show');
  });

  // 點外部關閉
  document.addEventListener('click', (e) => {
    if (!popup.contains(e.target) && e.target !== btn && !btn.contains(e.target)) {
      popup.classList.remove('show');
    }
  });

  // 主題選擇
  document.querySelectorAll('.theme-option').forEach(el => {
    el.addEventListener('click', () => {
      const theme = el.dataset.theme;
      applyTheme(theme);
      popup.classList.remove('show');
      showToast('已切換主題', 'success');
    });
  });
}

// ============================================
// HTML 跳脫（防 XSS）
// ============================================
function escapeHtml(str) {
  if (str == null) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function formatDate(timestamp) {
  if (!timestamp) return '—';
  const d = new Date(timestamp);
  const yyyy = d.getFullYear();
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  const dd = String(d.getDate()).padStart(2, '0');
  return `${yyyy}/${mm}/${dd}`;
}

