     - Firebase compat 版
     ============================================ -->
<script>
'use strict';

// ============================================
// 設定區（部署前需修改）
// ============================================
const FIREBASE_CONFIG = {
  // ⚠️ 部署前請填入實際 Firebase 設定
  apiKey: "YOUR_API_KEY",
  authDomain: "vvdouble-store.firebaseapp.com",
  databaseURL: "https://vvdouble-store-default-rtdb.firebaseio.com",
  projectId: "vvdouble-store",
  storageBucket: "vvdouble-store.appspot.com",
  messagingSenderId: "YOUR_SENDER_ID",
  appId: "YOUR_APP_ID"
};

// 8 個帳號的密碼設定（部署前請更換為隨機字串）
// 格式：店ID + 隨機字串
const STORE_PASSWORDS = {
  zhongxiao: "zhongxiao-7K2P",
  tongyi: "tongyi-3F9X",
  taoyuan: "taoyuan-M8N4",
  yizhong: "yizhong-5R2T",
  xinyizhong: "xinyizhong-J6Q1",
  xintiandi: "xintiandi-V7W3",
  xinjuejiang: "xinjuejiang-B9D5",
  V: "V-VVN-2026-MASTER"
};

// 店家中文名對照
const STORE_NAMES = {
  zhongxiao: "台北忠孝旗艦",
  tongyi: "台北統一 3F",
  taoyuan: "桃園 ATT",
  yizhong: "台中一中旗艦",
  xinyizhong: "台中新一中",
  xintiandi: "台南新天地 4F",
  xinjuejiang: "高雄新堀江",
  V: "總部 V"
};

const STORE_ORDER = [
  "zhongxiao", "tongyi", "taoyuan",
  "yizhong", "xinyizhong",
  "xintiandi", "xinjuejiang"
];

// ============================================
// 全域狀態
// ============================================
const state = {
  storeId: null,         // 當前登入的店 ID
  isHQ: false,           // 是否為總部 V
  currentStaff: null,    // 當前值班人員姓名
  staffList: [],         // 該店員工列表（員工管理用）
  selectedStaffId: null, // 登入流程中選中的員工 ID
  theme: 'sunshine'      // 當前主題
};

// Firebase 實例（初始化後賦值）
let db = null;

// ============================================
// 工具函數
// ============================================

/** 顯示 toast 訊息 */
function showToast(message, type = '') {
  const toast = document.getElementById('toast');
  toast.textContent = message;
  toast.className = 'toast show' + (type ? ' ' + type : '');
  setTimeout(() => {
    toast.className = 'toast' + (type ? ' ' + type : '');
  }, 2500);
}

/** 顯示/隱藏 loading */
function setLoading(show) {
  document.getElementById('loadingOverlay').classList.toggle('show', show);
}

/** 安全的 Firebase 寫入（含錯誤處理） */
async function safeWrite(path, data) {
  try {
    if (!db) throw new Error('Database not initialized');
    await db.ref(path).set(data);
    return { success: true };
  } catch (err) {
    console.error('Firebase write error:', err);
    showToast('儲存失敗：' + err.message, 'error');
    return { success: false, error: err };
  }
}

/** 安全的 Firebase 更新 */
async function safeUpdate(path, data) {
  try {
    if (!db) throw new Error('Database not initialized');
    await db.ref(path).update(data);
    return { success: true };
  } catch (err) {
    console.error('Firebase update error:', err);
    showToast('儲存失敗：' + err.message, 'error');
    return { success: false, error: err };
  }
}

/** 取頭像縮寫 */
function getAvatarText(name) {
  if (!name) return '?';
  // 中文取最後一字、英文取首字母
  return name.charAt(name.length - 1);
}

// ============================================
// Firebase 初始化
// ============================================
function initFirebase() {
  try {
    // 檢查設定是否已填入
    if (FIREBASE_CONFIG.apiKey === "YOUR_API_KEY") {
      console.warn('⚠️ Firebase 設定尚未填入，將以離線模式運行（無法儲存資料）');
      return false;
    }
    firebase.initializeApp(FIREBASE_CONFIG);
    db = firebase.database();
    console.log('✓ Firebase 連線成功');
    return true;
  } catch (err) {
    console.error('✗ Firebase 初始化失敗:', err);
    showToast('Firebase 連線失敗', 'error');
    return false;
  }
}

// ============================================
// 主題系統
// ============================================
function applyTheme(themeName) {
  if (themeName === 'sunshine') {
    document.documentElement.removeAttribute('data-theme');
  } else {
    document.documentElement.setAttribute('data-theme', themeName);
  }
  state.theme = themeName;

  // 更新 popup 中的選中狀態
  document.querySelectorAll('.theme-option').forEach(el => {
    el.classList.toggle('active', el.dataset.theme === themeName);
  });

  // 儲存到 sessionStorage（暫時的，正式做使用者偏好會寫 Firebase）
  try { sessionStorage.setItem('vvds_theme', themeName); } catch(e) {}

  // 若已登入，順便寫到 Firebase（個人偏好）
  if (db && state.storeId && state.currentStaff) {
    const path = state.isHQ
      ? `/global/userPrefs/V/theme`
      : `/stores/${state.storeId}/userPrefs/${state.currentStaff}/theme`;
    db.ref(path).set(themeName).catch(err => {
      console.warn('Theme preference save failed:', err);
    });
  }
}

function loadSavedTheme() {
  // 優先順序：Firebase > sessionStorage > 預設
  // (Firebase 載入會在登入後處理，這裡先用 sessionStorage)
  try {
    const saved = sessionStorage.getItem('vvds_theme');
    if (saved && ['sunshine', 'mint', 'candy'].includes(saved)) {
      applyTheme(saved);
      return;
    }
  } catch(e) {}
  applyTheme('sunshine');
}

async function loadUserThemeFromFirebase() {
  if (!db || !state.storeId) return;
  try {
    const path = state.isHQ
      ? `/global/userPrefs/V/theme`
      : `/stores/${state.storeId}/userPrefs/${state.currentStaff}/theme`;
    const snapshot = await db.ref(path).once('value');
    const theme = snapshot.val();
    if (theme && ['sunshine', 'mint', 'candy'].includes(theme)) {
      applyTheme(theme);
    }
  } catch(err) {
    console.warn('Theme preference load failed:', err);
  }
}

// ============================================
// 登入流程
// ============================================
function setupLoginScreen() {
  const stepOneBtn = document.getElementById('loginBtnStep1');
  const stepTwoBtn = document.getElementById('loginBtnStep2');
  const backBtn = document.getElementById('loginBtnBack');
  const passwordInput = document.getElementById('loginPassword');

  // Enter 鍵提交
  passwordInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') stepOneBtn.click();
  });

  stepOneBtn.addEventListener('click', handleLoginStep1);
  stepTwoBtn.addEventListener('click', handleLoginStep2);
  backBtn.addEventListener('click', handleLoginBack);
}

async function handleLoginStep1() {
  const storeId = document.getElementById('loginStoreId').value;
  const password = document.getElementById('loginPassword').value;
  const errorEl = document.getElementById('loginError');

  // 驗證
  if (!storeId) {
    errorEl.textContent = '請選擇店家';
    errorEl.classList.add('show');
    return;
  }
  if (!password) {
    errorEl.textContent = '請輸入密碼';
    errorEl.classList.add('show');
    return;
  }

  // 密碼比對
  const expectedPassword = STORE_PASSWORDS[storeId];
  if (password !== expectedPassword) {
    errorEl.textContent = '密碼錯誤';
    errorEl.classList.add('show');
    return;
  }

  errorEl.classList.remove('show');
  state.storeId = storeId;
  state.isHQ = (storeId === 'V');

  // 總部 V 直接進入主畫面（不需選值班人員）
  if (state.isHQ) {
    state.currentStaff = 'VVN';
    enterMainApp();
    return;
  }

  // 店長端：載入員工列表，進入 Step 2
  setLoading(true);
  try {
    await loadStaffListForLogin();
    document.getElementById('loginStep1').style.display = 'none';
    document.getElementById('loginStep2').style.display = 'block';
  } catch (err) {
    errorEl.textContent = '載入員工列表失敗：' + err.message;
    errorEl.classList.add('show');
  } finally {
    setLoading(false);
  }
}

async function loadStaffListForLogin() {
  if (!db) {
    // Firebase 未設定，顯示提示
    renderStaffSelectList([]);
    return;
  }
  const snapshot = await db.ref(`/stores/${state.storeId}/staff`).once('value');
  const data = snapshot.val() || {};
  state.staffList = Object.entries(data)
    .map(([id, info]) => ({ id, ...info }))
    .filter(s => s.active !== false);
  renderStaffSelectList(state.staffList);
}

function renderStaffSelectList(list) {
  const container = document.getElementById('staffSelectList');
  const btn = document.getElementById('loginBtnStep2');

  if (!list || list.length === 0) {
    container.innerHTML = '<div class="staff-empty">尚未建立員工，點下方「新增員工」開始</div>';
    btn.disabled = true;
    return;
  }

  container.innerHTML = list.map(s => `
    <div class="staff-option" data-id="${s.id}" data-name="${escapeHtml(s.name)}">
      <div class="staff-avatar">${escapeHtml(getAvatarText(s.name))}</div>
      <div class="staff-info">
        <div class="staff-name">${escapeHtml(s.name)}</div>
        <div class="staff-role">${escapeHtml(s.role || '店員')}</div>
      </div>
    </div>
  `).join('');

  // 綁定點選事件
  container.querySelectorAll('.staff-option').forEach(el => {
    el.addEventListener('click', () => {
      container.querySelectorAll('.staff-option').forEach(o => o.classList.remove('selected'));
      el.classList.add('selected');
      state.selectedStaffId = el.dataset.id;
      state.currentStaff = el.dataset.name;
      btn.disabled = false;
    });
  });
}

function handleLoginStep2() {
  if (!state.currentStaff) {
    showToast('請先選擇值班人員', 'error');
    return;
  }
  enterMainApp();
}

function handleLoginBack() {
  document.getElementById('loginStep1').style.display = 'block';
  document.getElementById('loginStep2').style.display = 'none';
  state.selectedStaffId = null;
  state.currentStaff = null;
}

function enterMainApp() {
  document.getElementById('loginScreen').style.display = 'none';
  document.getElementById('mainApp').style.display = 'block';

  // 更新 header 資訊
  document.getElementById('appTitle').textContent = STORE_NAMES[state.storeId] || '店長中心';
  document.getElementById('appSubtitle').textContent = state.isHQ
    ? `總部視角 · ${state.currentStaff}`
    : `值班：${state.currentStaff}`;

  // 更新歡迎詞
  const welcomeEl = document.getElementById('welcomeText');
  const hour = new Date().getHours();
  let greet = '';
  if (hour < 11) greet = '早安';
  else if (hour < 14) greet = '午安';
  else if (hour < 18) greet = '午後好';
  else greet = '晚安';

  welcomeEl.innerHTML = `${greet}，<strong>${escapeHtml(state.currentStaff)}</strong> ✿<br>這是 Phase 1.A 地基版本，後續模組將陸續上線。`;

  // 載入個人主題偏好
  loadUserThemeFromFirebase();

  // 儲存登入狀態到 sessionStorage（refresh 後保持）
  try {
    sessionStorage.setItem('vvds_session', JSON.stringify({
      storeId: state.storeId,
      isHQ: state.isHQ,
      currentStaff: state.currentStaff,
      selectedStaffId: state.selectedStaffId
    }));
  } catch (e) {}
}

function tryRestoreSession() {
  try {
    const raw = sessionStorage.getItem('vvds_session');
    if (!raw) return false;
    const session = JSON.parse(raw);
    if (!session.storeId || !session.currentStaff) return false;
    state.storeId = session.storeId;
    state.isHQ = session.isHQ;
    state.currentStaff = session.currentStaff;
    state.selectedStaffId = session.selectedStaffId;
    enterMainApp();
    return true;
  } catch (e) {
    return false;
  }
}

function handleLogout() {
  if (!confirm('確定要登出嗎？')) return;
  try {
    sessionStorage.removeItem('vvds_session');
  } catch (e) {}
  // 重置狀態
  state.storeId = null;
  state.isHQ = false;
  state.currentStaff = null;
  state.selectedStaffId = null;
  state.staffList = [];

  // 切回登入畫面
  document.getElementById('mainApp').style.display = 'none';
  document.getElementById('loginScreen').style.display = 'flex';
  document.getElementById('loginStep1').style.display = 'block';
  document.getElementById('loginStep2').style.display = 'none';
  document.getElementById('loginPassword').value = '';
  document.getElementById('loginStoreId').value = '';
}

